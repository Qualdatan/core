# === API ===
ANTHROPIC_API_KEY=sk-ant-api03-DEIN-KEY-HIER

# === Modell (ueberschreibt Recipe-Einstellung) ===
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MAX_TOKENS=16384

# === Analyse ===
# DEFAULT_RECIPE=mayring

# === Pfade ===
# Alle optional. Defaults sind relativ zum Projektroot. Absolute Pfade
# (z.B. /mnt/data/...) werden 1:1 uebernommen — so kannst du statische
# Daten (methods, codebases) und run-spezifische Daten (companies,
# transcripts) auch ausserhalb der Codebase ablegen.
#
# Statische Daten (ueber Runs hinweg geteilt):
# METHODS_DIR=./methods                  # frueher 'recipes/'
# CODEBASES_DIR=./input/codebases
#
# Run-spezifische Daten:
# COMPANIES_DIR=./input/companies        # neuer Company-Modus
# TRANSCRIPTS_DIR=./input/transcripts    # legacy: nur fuer 'transcripts'-Modus
# PROJECTS_DIR=./input/projects          # legacy: nur fuer 'documents'-Modus
#
# Output:
# OUTPUT_DIR=./output
# TRIANGULATION_DB=                      # default: <OUTPUT_DIR>/_triangulation.db
